  "rewrites": [
    {
      "source": "/growtree",
      "destination": "https://grow-tree-psi.vercel.app/growtree"
    },
    {
      "source": "/growtree/(.*)",
      "destination": "https://grow-tree-psi.vercel.app/growtree/$1"
    },
    {
      "source": "/realyou",
      "destination": "https://real-you-jet.vercel.app/realyou"
    },
    {
      "source": "/realyou/(.*)",
      "destination": "https://real-you-jet.vercel.app/realyou/$1"
    },
    {
      "source": "/talkscope",
      "destination": "https://talk-scope.vercel.app/"
    },
    {
      "source": "/talkscope/(.*)",
      "destination": "https://talk-scope.vercel.app/$1"
    }
  ]
}
