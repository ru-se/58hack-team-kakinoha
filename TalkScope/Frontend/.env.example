# ベクトルAPI（開発時プロキシ先）
VITE_BACKEND_URL=http://127.0.0.1:8000

# 前回送信とかぶらせる文の数（未設定時は 5）
VITE_VECTOR_OVERLAP_SENTENCES=5

# 新規にこの文数たまったら送信（未設定時は 5。0で無効）
VITE_VECTOR_SEND_EVERY_N_SENTENCES=10

# この秒数ごとに送信（0で無効）。文数トリガーと併用可
VITE_VECTOR_SEND_INTERVAL_SEC=60

VITE_EXTERNAL_API_URL=http://localhost:3001/api/quizzes/generate

